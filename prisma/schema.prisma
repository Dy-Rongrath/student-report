// Prisma schema for student-report-app
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Report {
  id         String   @id @default(cuid())
  name       String
  term       String
  date       DateTime
  percentage Float?
  data       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
