// Prisma schema for student-report-app
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Report {
  id         String   @id @default(cuid())
  name       String
  term       String
  date       DateTime
  percentage Float?
  data       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Link to Student (optional for backfill; code will set it going forward)
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([studentId])
}

model Student {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reports   Report[]
}
